// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User - managed by Clerk, we just store the relation
model User {
  id        String   @id // Clerk user ID
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apps        App[]
  dataSources DataSource[]
  subscriptions Subscription[]
  templates   Template[]
}

// App - the published portals
model App {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  
  // Branding
  logo        String?
  primaryColor String  @default("#2563EB")
  customDomain String?

  // Public sharing
  isPublic    Boolean  @default(false)
  publicPassword String?  // Optional password protection
  publicAccessToken String?  // Token for shared links

  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  dataSources DataSource[]
  blocks      Block[]
  roles       Role[]
  analytics   AppAnalytics[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// DataSource - Notion connections
model DataSource {
  id            String   @id @default(cuid())
  name          String
  type          String   @default("notion") // notion, etc.
  
  // Notion specific
  notionAccessToken String?
  notionWorkspaceId String?
  notionWorkspaceName String?
  
  // Connection status
  connected     Boolean  @default(false)
  lastSyncAt    DateTime?
  
  // Relations
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  appId         String?
  app           App?     @relation(fields: [appId], references: [id], onDelete: Cascade)
  
  notionDatabases NotionDatabase[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// NotionDatabase - synced databases from Notion
model NotionDatabase {
  id            String   @id @default(cuid())
  notionId      String   @unique
  name          String
  icon          String?
  
  // Field mappings
  schema        Json     // Field name -> type mapping
  
  // Relations
  dataSourceId  String
  dataSource    DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  
  syncedRows    SyncedRow[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// SyncedRow - cached rows from Notion
model SyncedRow {
  id            String   @id @default(cuid())
  notionId      String   @unique
  properties    Json
  lastEditedTime String
  url           String?
  
  // Sync metadata
  syncedAt      DateTime @default(now())
  
  // Relations
  databaseId    String
  database      NotionDatabase @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([databaseId, lastEditedTime])
}

// Block - visual blocks in the builder
model Block {
  id          String   @id @default(cuid())
  type        String   // table, cards, detail, form
  config      Json     // block-specific config
  
  position    Int      @default(0)
  
  // Relations
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Role - user roles in an app
model Role {
  id          String   @id @default(cuid())
  name        String   // admin, editor, viewer
  permissions Json     // permission config
  
  // Relations
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  
  userRoles   UserRole[]
  
  createdAt   DateTime @default(now())
}

// UserRole - user role assignments
model UserRole {
  id        String   @id @default(cuid())
  
  // User reference (Clerk ID)
  userId    String
  email     String
  
  // Relations
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([userId, roleId])
}

// Notification - user notifications
model Notification {
  id          String   @id @default(cuid())
  type        String   // app_published, data_synced, role_changed, etc.
  title       String
  message     String
  read        Boolean  @default(false)
  readAt      DateTime?
  
  // Link to related entity
  link        String?
  entityType  String?  // app, datasource, role
  entityId    String?
  
  // User reference
  userId      String
  
  createdAt   DateTime @default(now())
  
  @@index([userId, read])
  @@index([createdAt])
}

// AuditLog - system audit logs
model AuditLog {
  id          String   @id @default(cuid())
  
  // Action details
  action      String   // created, updated, deleted, published, etc.
  entityType  String   // app, block, datasource, role, user
  entityId    String?
  
  // Change details
  changes     Json?    // { before: {}, after: {} }
  
  // User who performed the action
  userId      String?
  userEmail   String?
  
  // IP address
  ipAddress   String?
  
  // App context (for multi-tenant)
  appId       String?
  
  createdAt   DateTime @default(now())
  
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

// Subscription - Stripe subscriptions
model Subscription {
  id              String   @id @default(cuid())
  
  // Stripe data
  stripeCustomerId String?
  stripeSubscriptionId String?
  stripePriceId   String?
  status          String   @default("inactive") // active, canceled, past_due
  
  // Plan limits
  plan            String   @default("free") // free, pro, agency
  appsLimit       Int      @default(1)
  usersLimit      Int      @default(100)
  customDomain    Boolean  @default(false)
  
  // Relations
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  currentPeriodEnd DateTime?
}

// Template - Marketplace templates (user-created)
model Template {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String?
  category    String   @default("custom") // crm, internal, projects, custom
  
  // Template data (blocks configuration)
  blocks      Json
  
  // Publishing
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  
  // Stats
  downloads   Int      @default(0)
  rating      Float    @default(0)
  
  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([category])
  @@index([published])
}

// AppAnalytics - Basic analytics for apps
model AppAnalytics {
  id          String   @id @default(cuid())
  
  // Event types: page_view, row_view, form_submit, etc.
  eventType   String
  
  // Event data
  metadata    Json?
  
  // Session/user info
  sessionId   String?
  userAgent   String?
  ipAddress   String?
  
  // Relations
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@index([appId, createdAt])
  @@index([eventType, createdAt])
}
